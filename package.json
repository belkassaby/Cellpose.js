{
  "name": "cellpose-js",
  "version": "0.1.1",
  "description": "Browser-side cellular segmentation via Cellpose-SAM, running on WebGPU.",
  "type": "module",
  "license": "MIT",
  "author": "Baha Elkassaby",
  "homepage": "https://github.com/belkassaby/Cellpose.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belkassaby/Cellpose.js.git"
  },
  "bugs": {
    "url": "https://github.com/belkassaby/Cellpose.js/issues"
  },
  "keywords": [
    "cellpose",
    "segmentation",
    "webgpu",
    "onnx",
    "microscopy",
    "cell-segmentation"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webgpu-worker": "./dist/inference.worker.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "vite",
    "demo": "vite serve examples/demo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint --fix src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.{ts,html}\" \"*.{ts,json,md}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.{ts,html}\" \"*.{ts,json,md}\" \"docs/**/*.md\""
  },
  "peerDependencies": {
    "onnxruntime-web": "~1.26.0"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.70",
    "eslint": "^9.39.4",
    "onnxruntime-web": "~1.26.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
